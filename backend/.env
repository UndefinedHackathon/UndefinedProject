# StockPilot AI — Backend Environment Variables

# Sunucu
PORT=3001
NODE_ENV=development

# PostgreSQL (Emre dolduracak)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stockpilot
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stockpilot
DB_USER=postgres
DB_PASSWORD=postgres

# Gemma / Ollama AI
GEMMA_BASE_URL=http://localhost:11434
GEMMA_MODEL=gemma3:4b
GEMMA_TIMEOUT=15000

# Demo Mode (Auth çalışmazsa bypass)
DEMO_MODE=true

# Firebase (Taha dolduracak)
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=
